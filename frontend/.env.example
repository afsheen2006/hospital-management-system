# =====================================================
# MediCare+ Smart Hospital Frontend - Environment Configuration
# =====================================================
# Copy this file to .env and fill in your values
# Do NOT commit .env to version control
# =====================================================

# --- API Configuration ---
# Development: http://localhost:5000/api/v1
# Production: https://your-api-domain.com/api/v1
VITE_API_URL=http://localhost:5000/api/v1

# --- Optional: Analytics & Monitoring ---
# Uncomment and configure if using analytics services
# VITE_SENTRY_DSN=your_sentry_dsn_here
# VITE_GOOGLE_ANALYTICS_ID=your_ga_id_here

# =====================================================
# Setup Instructions:
# =====================================================
# 1. Copy .env.example to .env: cp .env.example .env
# 2. Update VITE_API_URL to match your backend URL
# 3. For local development, use http://localhost:5000/api/v1
# 4. For production, use your deployed backend URL
# 5. Never commit .env to git (it's in .gitignore)
# =====================================================

# Note: All variables must start with VITE_ to be accessible in Vite
