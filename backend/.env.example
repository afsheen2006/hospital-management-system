# =====================================================
# MediCare+ Smart Hospital - Environment Configuration
# =====================================================
# Copy this file to .env and fill in your own values
# Do NOT commit .env to version control
# =====================================================

# --- Server Configuration ---
NODE_ENV=development
PORT=5000

# --- Database Configuration ---
# Local: mongodb://localhost:27017/medicare_smart_hospital
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/medicare_smart_hospital
MONGO_URI=mongodb://localhost:27017/medicare_smart_hospital

# --- Authentication (JWT) ---
# Generate a secure secret key (min 32 characters)
# Command: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
JWT_EXPIRE=7d

# --- AI Integration (Groq API) ---
# Get from: https://console.groq.com/
# Required for: Symptom analysis, report summarization, health risk prediction
# Using model: llama-3.3-70b-versatile
GROQ_API_KEY=your_groq_api_key_here

# --- File Storage (Cloudinary) ---
# Get from: https://cloudinary.com/
# Required for: Medical reports, prescriptions, profile images
# Features: Auto-optimization, CDN delivery, secure storage
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# --- Email Configuration (Nodemailer) ---
# Gmail: Requires App Password (not account password)
# Setup: https://support.google.com/accounts/answer/185833
# Services available: gmail, outlook, yahoo, custom SMTP
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=MediCare+ Hospital <noreply@medicare.com>

# --- Frontend Configuration ---
# For CORS whitelist - must match frontend domain exactly
# Dev: http://localhost:3000
# Prod: https://yourdomain.com
FRONTEND_URL=http://localhost:3000

# --- Optional: Google OAuth ---
# Get from: https://console.developers.google.com/
# Scopes needed: email, profile
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# --- Optional: Hospital Information ---
# Used in email templates and system identity
HOSPITAL_NAME=MediCare+ Smart Hospital
HOSPITAL_ADDRESS=123 Medical Center Drive, Healthcare City 45678
HOSPITAL_PHONE=(555) 123-4567
HOSPITAL_EMAIL=contact@medicareplus.com

# =====================================================
# Setup Instructions:
# =====================================================
# 1. Copy .env.example to .env: cp .env.example .env
# 2. Fill in all required fields with your actual values
# 3. For local development, you can use localhost for MongoDB
# 4. For production, use Atlas MongoDB connection string
# 5. Never commit .env to git (it's in .gitignore)
# 6. Keep .env secure - contains sensitive information
# =====================================================

